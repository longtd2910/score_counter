<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/live_activity_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@color/black"
    android:padding="8dp">

    <!-- PLAYER SLOT 1 -->
    <LinearLayout
        android:id="@+id/player_slot_1"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/player1_score"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/circle_red"
            android:gravity="center"
            android:text="24"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/player1_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Long"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- SEPARATOR -->
    <ImageView
        android:id="@+id/separator_1"
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="8dp"
        android:src="@drawable/separator" />

    <!-- PLAYER SLOT 2 -->
    <LinearLayout
        android:id="@+id/player_slot_2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/player2_score"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/circle_green"
            android:gravity="center"
            android:text="4"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/player2_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Đức"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- SEPARATOR -->
    <ImageView
        android:id="@+id/separator_2"
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="8dp"
        android:src="@drawable/separator" />

    <!-- PLAYER SLOT 3 -->
    <LinearLayout
        android:id="@+id/player_slot_3"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/player3_score"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/circle_yellow"
            android:gravity="center"
            android:text="-28"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/player3_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Minh"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- SEPARATOR -->
    <ImageView
        android:id="@+id/separator_3"
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_marginHorizontal="8dp"
        android:src="@drawable/separator" />

    <!-- PLAYER SLOT 4 -->
    <LinearLayout
        android:id="@+id/player_slot_4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:id="@+id/player4_score"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/circle_blue"
            android:gravity="center"
            android:text="0"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/player4_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="(empty)"
            android:textColor="@android:color/white"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

</LinearLayout>
